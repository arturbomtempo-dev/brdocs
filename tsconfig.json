{
    "compilerOptions": {
        "target": "ES2022",

        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,

        "skipLibCheck": true,

        "isolatedModules": true,

        "esModuleInterop": true,

        "resolveJsonModule": true,

        "types": ["node"],

        "noUncheckedIndexedAccess": true,

        "forceConsistentCasingInFileNames": true
    },

    "include": ["src", "tests"]
}
